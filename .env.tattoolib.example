# Variables d'environnement pour TattooLib Planning

# Configuration des Availabilities
AVAILABILITY_WINDOW_DAYS=90
AVAILABILITY_INITIAL_DAYS=365
AVAILABILITY_KEEP_PAST_DAYS=30
CLIENT_SEARCH_LIMIT_MONTHS=3

MIN_SLOT_DURATION=30
MAX_SLOT_DURATION=480
SLOT_BUFFER_MINUTES=15

# Configuration Booking Requests
DEFAULT_DEPOSIT_DEADLINE_HOURS=72
DEFAULT_DEPOSIT_RATE=30
TATTOOER_RESPONSE_DEADLINE_HOURS=48
MAX_INCLUDED_DESIGN_VERSIONS=3

# Configuration Planning
DEFAULT_PLANNING_VIEW=week
DEFAULT_START_TIME=09:00
DEFAULT_END_TIME=18:00
DEFAULT_BREAK_START=12:00
DEFAULT_BREAK_END=13:00

# Notifications
APPOINTMENT_REMINDER_HOURS_BEFORE=24,2
EXPIRED_REQUEST_NOTIFICATION_ENABLED=true
NEW_BOOKING_NOTIFICATION_ENABLED=true
