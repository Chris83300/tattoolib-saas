APP_NAME="TattooLib SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://tattoolib-saas.test

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tattoolib_saas
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=media
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"



VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=


FIREBASE_CREDENTIALS=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

SANCTUM_TOKEN_PREFIX='api'

# Configuration des Availabilities
AVAILABILITY_WINDOW_DAYS=90
AVAILABILITY_INITIAL_DAYS=365
AVAILABILITY_KEEP_PAST_DAYS=30
CLIENT_SEARCH_LIMIT_MONTHS=3

MIN_SLOT_DURATION=30
MAX_SLOT_DURATION=480
SLOT_BUFFER_MINUTES=15

# Configuration Booking Requests
DEFAULT_DEPOSIT_DEADLINE_HOURS=72
DEFAULT_DEPOSIT_RATE=30
TATTOOER_RESPONSE_DEADLINE_HOURS=48
MAX_INCLUDED_DESIGN_VERSIONS=3

# Configuration Planning
DEFAULT_PLANNING_VIEW=week
DEFAULT_START_TIME=09:00
DEFAULT_END_TIME=18:00
DEFAULT_BREAK_START=12:00
DEFAULT_BREAK_END=13:00

# Notifications
APPOINTMENT_REMINDER_HOURS_BEFORE=24,2
EXPIRED_REQUEST_NOTIFICATION_ENABLED=true
NEW_BOOKING_NOTIFICATION_ENABLED=true

# Stripe
STRIPE_WEBHOOK_SECRET=
STRIPE_KEY=
STRIPE_SECRET=


STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_STUDIO=
STRIPE_PRICE_ID_STUDIO_EXTRA=

# Prix Abonnement Stripe Billing
STRIPE_PRICE_STARTER=9.99
STRIPE_PRICE_PRO=29.99
STRIPE_PRICE_STUDIO=59.99
STRIPE_PRICE_STUDIO_EXTRA=24.99

# Beta
STRIPE_BETA_COUPON_ID=

# Montant acompte par défaut (en centimes)
STRIPE_DEFAULT_DEPOSIT_AMOUNT=5000  # 50€
STRIPE_DEFAULT_DEPOSIT_PERCENTAGE=30  # 30% du total

CASHIER_CURRENCY=eur
CASHIER_CURRENCY_LOCALE=fr

 APP_CGU_VERSION=1.0
